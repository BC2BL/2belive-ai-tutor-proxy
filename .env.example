# ---- Required ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Model (switch anytime without redeploying code) ----
# "sonnet" | "haiku" | any full Anthropic model string
TUTOR_MODEL=sonnet
MAX_OUTPUT_TOKENS=400

# ---- Credits ----
INITIAL_CREDITS=100
DAILY_CAP=50

# ---- Abuse controls ----
MAX_MESSAGE_CHARS=500
MAX_HISTORY_TURNS=12
MIN_SECONDS_BETWEEN=3

# ---- CORS: lock to the 2BeLive player origin in production ----
ALLOWED_ORIGIN=*

# ---- Admin ----
ADMIN_SECRET=change-me-to-a-long-random-string

# ---- Storage: Upstash Redis (REQUIRED for production on Vercel) ----
# Without these, credits are in-memory and reset between serverless invocations.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
